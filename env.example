# Copy to .env on the T480s. NEVER commit (add .env to .gitignore).

NTFY_SERVER=https://ntfy.sh
NTFY_TOKEN=tk_xxxxxxxxxxxxxxxxxxxxx
NTFY_REPORT_TOPIC=mystocks-report-x7k2

# Stage 1 universe discovery uses the free Nasdaq screener — NO API key needed.

# ── The hub (site/api.php) — results + verdicts are pushed/read here ──
# SCANNER_API_TOKEN must match api_config.php on the server. The Claude routine
# does NOT store this — run_scan.sh passes it (and the URLs) in the fire payload,
# since web routines have no secure secret store. Git is code-only now.
SCANNER_API_URL=https://scanner.example.com/api.php
SCANNER_API_TOKEN=change-me-to-a-long-random-string

# ── Static asset deploy (publish.sh rsyncs site/ to zone.ee over SSH) ──
# Only needed when the site CODE changes; data flows via the hub above.
ZONE_SSH_HOST=yourname.zone.ee
ZONE_SSH_USER=yourname
ZONE_SSH_PATH=/data01/virtXXXXX/domeenid/www.example.ee/htdocs
ZONE_SSH_PORT=22
# Public dashboard URL — added as the ntfy notification's tap-through link.
DASHBOARD_URL=https://scanner.example.com/

# Claude Code routine API trigger (needs "Claude Code on the web" enabled).
# Routine editor → Add trigger → API → Generate token. Both shown ONCE.
CLAUDE_ROUTINE_ID=your_routine_id
CLAUDE_ROUTINE_TOKEN=token_shown_once
# Beta header may rotate during research preview; verify at platform.claude.com
CLAUDE_BETA_HEADER=experimental-cc-routine-2026-04-01
